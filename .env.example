PAYPAL_CLIENT_SECRET=""

# AI/ML
OPENAI_API_KEY=""
GOOGLE_AI_API_KEY=""
HUGGINGFACE_API_KEY=""
PINECONE_API_KEY=""
PINECONE_ENVIRONMENT=""

# Maps
GOOGLE_MAPS_API_KEY=""

# Cloud Storage
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""
CLOUDFLARE_R2_ACCESS_KEY=""
CLOUDFLARE_R2_SECRET_KEY=""
